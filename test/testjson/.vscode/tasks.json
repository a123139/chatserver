{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build testjson",
            "type": "shell",
            "command": "bash",
            "args": [
                "-c",
                "cd /root/projects/testjson && scl enable devtoolset-7 -- g++ testjson.cpp -o testjson -std=c++17 -g"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": []
        },
        {
            "type": "cppbuild",
            "label": "C/C++: gcc 生成活动文件",
            "command": "/opt/rh/devtoolset-7/root/usr/bin/gcc",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "调试器生成的任务。"
        }
    ]
}